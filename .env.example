# Zendesk API credentials
# Subdomain only: for https://yourcompany.zendesk.com use "yourcompany"
ZENDESK_SUBDOMAIN=yourcompany
# Email of the agent/admin the API token belongs to
ZENDESK_EMAIL=agent@yourcompany.com
# API token from Admin Center > Apps and integrations > APIs > Zendesk API
ZENDESK_API_TOKEN=your-zendesk-api-token

# OpenAI
OPENAI_API_KEY=sk-...
# Optional, defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
